{
  "name": "deem2",
  "private": true,
  "workspaces": [
    "backend",
    "mobile"
  ],
  "devDependencies": {
    "concurrently": "^9.2.1",
    "husky": "^9.1.7",
    "lint-staged": "^16.3.2",
    "prettier": "^3.8.1",
    "typescript-eslint": "^8.56.1"
  },
  "scripts": {
    "dev": "concurrently -k -n BACKEND,MOBILE \"npm -w backend run dev\" \"npm -w mobile run dev\"",
    "dev:backend": "npm -w backend run dev",
    "dev:mobile": "npm -w mobile run dev",
    "dev:ios": "npm -w mobile run ios",
    "dev:android": "npm -w mobile run android",
    "format": "prettier . --write",
    "format:check": "prettier . --check",
    "lint": "npm run lint -w backend && npm run lint -w mobile",
    "prepare": "husky",
    "infra:up": "docker compose -f backend/docker-compose.yml up -d",
    "infra:down": "docker compose -f backend/docker-compose.yml down",
    "prisma:migrate": "prisma migrate dev --config prisma.config.ts",
    "prisma:generate": "prisma generate --config prisma.config.ts"
  },
  "lint-staged": {
    "*.{ts,tsx,js,json,md}": [
      "prettier --write"
    ],
    "backend/**/*.{ts,js}": [
      "npm run lint -w backend --"
    ],
    "mobile/**/*.{ts,tsx,js}": [
      "npm run lint -w mobile --"
    ]
  }
}
